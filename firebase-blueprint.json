{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "barber", "admin"] },
        "phoneNumber": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "Available barber services.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["name", "price", "duration"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Service appointments.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "barberId": { "type": "string" },
        "serviceId": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "type": { "type": "string", "enum": ["salon", "home"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "createdAt": { "type": "string" }
      },
      "required": ["customerId", "barberId", "serviceId", "date", "time", "status", "type"]
    },
    "BarberLocation": {
      "title": "Barber Location",
      "description": "Real-time location of barbers for home services.",
      "type": "object",
      "properties": {
        "barberId": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "lastUpdated": { "type": "string" }
      },
      "required": ["barberId", "lat", "lng", "lastUpdated"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles."
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Available services."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Appointment bookings."
    },
    "/barberLocations/{barberId}": {
      "schema": "BarberLocation",
      "description": "Real-time barber tracking."
    }
  }
}
